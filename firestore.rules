rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // الكويز يكتب lead جديد فقط — ممنوع القراءة/التعديل/الحذف من المتصفح
    match /leads/{id} {
      allow create: if request.resource.data.source == 'abundance-quiz'
                    && request.resource.data.keys().hasOnly(
                         ['source','segment','scores','answers','purchased','createdAt']);
      allow read, update, delete: if false;
    }

    // الطلبات والدفعات: السيرفر فقط (Cloud Functions) — مغلقة تماماً للمتصفح
    match /orders/{id} {
      allow read, write: if false;
    }

    // أي شيء ثاني مرفوض
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
